# SIAOL-PRO v7 - Variaveis de Ambiente
# Copie este arquivo para .env e preencha com suas credenciais reais

# Supabase (Banco de Dados)
SUPABASE_URL="sua_url_do_supabase"
SUPABASE_KEY="sua_chave_anon_do_supabase"

# Groq (IA Gratuita - Motor Primario)
# Obtenha em: https://console.groq.com
GROQ_API_KEY="sua_chave_groq"

# Google Gemini (IA Gratuita - Motor Secundario)
# Obtenha em: https://aistudio.google.com/apikey
GEMINI_API_KEY="sua_chave_gemini"
